# PostHog API Key
# Get your project key at https://us.posthog.com/project/settings
# Note: Host is configured via reverse proxy in next.config.ts
NEXT_PUBLIC_POSTHOG_KEY=phc_...

# OpenAI API key — powers the "Ask" feature (server-side only, never exposed
# to the client). Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Upstash Redis — distributed rate limiting for the "Ask" endpoint. Optional in
# local dev (falls back to an in-memory limiter when unset). Provision a free
# database at https://console.upstash.com and copy the REST URL + token.
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# Optional salt for anonymizing IPs in server-side analytics (Ask). A random
# string; if unset a built-in default is used.
ASK_IP_SALT=change-me

# MailerLite (weekly quote email) — server-side only, never NEXT_PUBLIC_
# Create an API token at https://dashboard.mailerlite.com/integrations/api
MAILERLITE_API_KEY=ml_...
# Group IDs per locale (weekly cadence)
MAILERLITE_GROUP_EN=
MAILERLITE_GROUP_ES=
MAILERLITE_GROUP_DE=
MAILERLITE_GROUP_FR=
# Verified sending identity
MAILERLITE_FROM_EMAIL=quotes@lawofone.study
MAILERLITE_FROM_NAME=Law of One Study

# Shared secret Vercel Cron sends in the Authorization header
CRON_SECRET=
