{
  "songId": "first-breath",
  "cues": [
    {
      "start": 14.0,
      "end": 17.0,
      "text": "The universe breathes out",
      "animationHint": "expand"
    },
    {
      "start": 19.0,
      "end": 21.32,
      "text": "a single thought of light"
    },
    {
      "start": 34.0,
      "end": 38.32,
      "text": "The fire learns that it is fire"
    },
    {
      "start": 38.32,
      "end": 40.78,
      "text": "the water finds the night"
    },
    {
      "start": 40.78,
      "end": 44.96,
      "text": "the stone has no name to call its own"
    },
    {
      "start": 44.96,
      "end": 48.48,
      "text": "but leans toward the light"
    },
    {
      "start": 48.48,
      "end": 57.36,
      "text": "the first dim spark of knowing",
      "animationHint": "spark"
    },
    {
      "start": 51.0,
      "end": 55.0,
      "text": "in a world without a why"
    },
    {
      "start": 64.16,
      "end": 67.02,
      "text": "And from the silence something stirs"
    },
    {
      "start": 68.02,
      "end": 71.0,
      "text": "too quiet yet to hear"
    },
    {
      "start": 71.0,
      "end": 75.86,
      "text": "the elements remembering"
    },
    {
      "start": 74.0,
      "end": 80.32,
      "text": "they all began from here"
    },
    {
      "start": 80.32,
      "end": 83.43,
      "text": "no word for what is rising"
    },
    {
      "start": 83.43,
      "end": 86.16,
      "text": "no self to call it mine"
    },
    {
      "start": 86.0,
      "end": 98.61,
      "text": "just light learning to hold a shape",
      "animationHint": "rise"
    },
    {
      "start": 90.0,
      "end": 96.0,
      "text": "and shape learning to keep time"
    },
    {
      "start": 117.61,
      "end": 121.12,
      "text": "not finished, only starting"
    },
    {
      "start": 121.12,
      "end": 123.77,
      "text": "just opening its eyes"
    },
    {
      "start": 123.77,
      "end": 128.2,
      "text": "already pulled toward a brightness"
    },
    {
      "start": 128.2,
      "end": 132.44,
      "text": "it has no name to call"
    },
    {
      "start": 132.44,
      "end": 139.0,
      "text": "the universe is dreaming"
    },
    {
      "start": 139.0,
      "end": 144.03,
      "text": "and the dream is waking now",
      "animationHint": "bloom"
    }
  ]
}
