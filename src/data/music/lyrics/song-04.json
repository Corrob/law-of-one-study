{
  "songId": "known",
  "cues": [
    {
      "start": 16.02,
      "end": 18.42,
      "text": "And the veil lifts like the dawn"
    },
    {
      "start": 19.34,
      "end": 21.48,
      "text": "and I know you from inside"
    },
    {
      "start": 22.5,
      "end": 25.34,
      "text": "every heart becomes transparent",
      "animationHint": "shimmer"
    },
    {
      "start": 25.96,
      "end": 28.26,
      "text": "there is nowhere left to hide"
    },
    {
      "start": 28.9,
      "end": 31.84,
      "text": "the walls I built to keep me safe"
    },
    {
      "start": 33.24,
      "end": 35.12,
      "text": "dissolve like morning frost"
    },
    {
      "start": 35.78,
      "end": 38.54,
      "text": "and everything I thought I'd lost"
    },
    {
      "start": 40.0,
      "end": 41.78,
      "text": "was never really lost"
    },
    {
      "start": 43.5,
      "end": 46.06,
      "text": "And the one I called a stranger"
    },
    {
      "start": 46.82,
      "end": 48.9,
      "text": "was always only me"
    },
    {
      "start": 49.84,
      "end": 52.8,
      "text": "I can feel you from the inside"
    },
    {
      "start": 52.8,
      "end": 55.8,
      "text": "the way the blind must finally see"
    },
    {
      "start": 56.4,
      "end": 59.56,
      "text": "we are many voices singing"
    },
    {
      "start": 60.04,
      "end": 62.96,
      "text": "in a single rising tone"
    },
    {
      "start": 62.96,
      "end": 65.62,
      "text": "we were never cut apart"
    },
    {
      "start": 66.86,
      "end": 73.0,
      "text": "we were always, always known",
      "animationHint": "bloom"
    },
    {
      "start": 82.76,
      "end": 85.84,
      "text": "there's so much farther still to go —"
    },
    {
      "start": 86.74,
      "end": 90.26,
      "text": "I can hear you think before you speak,"
    },
    {
      "start": 90.26,
      "end": 92.82,
      "text": "and love is only half the light;"
    },
    {
      "start": 93.7,
      "end": 96.36,
      "text": "the colder half is what I seek"
    },
    {
      "start": 96.6,
      "end": 99.96,
      "text": "but oh — to feel you as myself,"
    },
    {
      "start": 100.94,
      "end": 103.78,
      "text": "to lose the lonely \"I\" —"
    },
    {
      "start": 104.04,
      "end": 106.88,
      "text": "every tear I left behind me"
    },
    {
      "start": 107.46,
      "end": 110.0,
      "text": "was a seed beneath this sky",
      "animationHint": "rise"
    }
  ]
}
