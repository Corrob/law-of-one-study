{
  "songId": "cold-light",
  "cues": [
    {
      "start": 20.92,
      "end": 23.66,
      "text": "The light grew cold and brilliant"
    },
    {
      "start": 25.1,
      "end": 28.3,
      "text": "I can see but cannot feel"
    },
    {
      "start": 29.56,
      "end": 32.62,
      "text": "I know the name of every star"
    },
    {
      "start": 33.1,
      "end": 36.24,
      "text": "and forget the ones are real"
    },
    {
      "start": 39.0,
      "end": 42.72,
      "text": "I have mapped the whole cathedral"
    },
    {
      "start": 43.7,
      "end": 47.18,
      "text": "every arch and every stone"
    },
    {
      "start": 47.18,
      "end": 50.42,
      "text": "and I am standing in the center"
    },
    {
      "start": 51.94,
      "end": 56.08,
      "text": "of a knowing — all alone"
    },
    {
      "start": 59.26,
      "end": 62.28,
      "text": "All this wisdom, all this light"
    },
    {
      "start": 63.88,
      "end": 67.18,
      "text": "and a question I can't drown:"
    },
    {
      "start": 68.1,
      "end": 71.8,
      "text": "what is knowing for, if knowing"
    },
    {
      "start": 72.98,
      "end": 76.82,
      "text": "only ever weighs me down?"
    },
    {
      "start": 76.86,
      "end": 80.86,
      "text": "I can hold the shape of everything"
    },
    {
      "start": 82.44,
      "end": 85.08,
      "text": "and warm not even one —"
    },
    {
      "start": 86.44,
      "end": 88.62,
      "text": "is this the whole of wisdom,"
    },
    {
      "start": 90.46,
      "end": 101.0,
      "text": "or only half the sun?"
    },
    {
      "start": 102.38,
      "end": 104.76,
      "text": "For wisdom still awaiting love"
    },
    {
      "start": 106.62,
      "end": 109.66,
      "text": "is a lantern with no flame"
    },
    {
      "start": 110.0,
      "end": 112.86,
      "text": "it shows me every doorway"
    },
    {
      "start": 113.22,
      "end": 117.06,
      "text": "but it cannot say my name"
    },
    {
      "start": 118.86,
      "end": 121.78,
      "text": "and somewhere past the brilliance"
    },
    {
      "start": 122.48,
      "end": 127.06,
      "text": "something soft begins to ache —"
    },
    {
      "start": 127.22,
      "end": 130.04,
      "text": "the first cold hint that knowing"
    },
    {
      "start": 131.96,
      "end": 134.26,
      "text": "was never the whole shape"
    },
    {
      "start": 147.18,
      "end": 150.4,
      "text": "I do not have the answer yet"
    },
    {
      "start": 152.06,
      "end": 156.5,
      "text": "I only have the ache —"
    },
    {
      "start": 156.66,
      "end": 159.42,
      "text": "and maybe that's the doorway"
    },
    {
      "start": 160.0,
      "end": 163.86,
      "text": "that the wisdom couldn't make"
    }
  ]
}
