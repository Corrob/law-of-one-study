{
  "songId": "behind-the-veil",
  "cues": [
    {
      "start": 16.84,
      "end": 19.26,
      "text": "Then the veil came down upon me"
    },
    {
      "start": 20.2,
      "end": 22.46,
      "text": "and I woke up in the dark"
    },
    {
      "start": 23.4,
      "end": 26.6,
      "text": "I am lost behind a curtain"
    },
    {
      "start": 27.0,
      "end": 29.24,
      "text": "I cannot find the spark"
    },
    {
      "start": 30.26,
      "end": 33.74,
      "text": "there's a hunger that would take the world"
    },
    {
      "start": 33.74,
      "end": 36.24,
      "text": "and keep it all alone"
    },
    {
      "start": 37.26,
      "end": 40.0,
      "text": "or a quiet, stranger longing"
    },
    {
      "start": 41.12,
      "end": 45.0,
      "text": "to love it as my own"
    },
    {
      "start": 45.26,
      "end": 48.4,
      "text": "The road splits here in the dark"
    },
    {
      "start": 48.56,
      "end": 51.76,
      "text": "no torch, no guide, no sign"
    },
    {
      "start": 51.82,
      "end": 54.62,
      "text": "two hands are reaching out of me"
    },
    {
      "start": 55.12,
      "end": 58.6,
      "text": "one is yours and one is mine"
    },
    {
      "start": 58.6,
      "end": 62.02,
      "text": "I can't see behind the veil"
    },
    {
      "start": 62.02,
      "end": 65.46,
      "text": "I can't tell the false from true"
    },
    {
      "start": 66.06,
      "end": 68.28,
      "text": "but the choosing is the only torch"
    },
    {
      "start": 68.78,
      "end": 91.98,
      "text": "I carry, walking through"
    },
    {
      "start": 91.98,
      "end": 94.36,
      "text": "I feel a pull I cannot name"
    },
    {
      "start": 94.7,
      "end": 96.58,
      "text": "a voice beneath the dark"
    },
    {
      "start": 97.1,
      "end": 100.16,
      "text": "as if some part of me I lost"
    },
    {
      "start": 101.26,
      "end": 103.74,
      "text": "is reaching for my heart"
    },
    {
      "start": 103.88,
      "end": 107.36,
      "text": "I cannot see the hand that pulls"
    },
    {
      "start": 107.36,
      "end": 110.16,
      "text": "I cannot know the guide"
    },
    {
      "start": 110.36,
      "end": 113.06,
      "text": "but something in me recognizes"
    },
    {
      "start": 113.48,
      "end": 116.46,
      "text": "what lives on the other side"
    },
    {
      "start": 119.44,
      "end": 124.88,
      "text": "I choose the light, I choose the light"
    },
    {
      "start": 125.18,
      "end": 128.42,
      "text": "I cannot see where it will lead"
    },
    {
      "start": 128.44,
      "end": 131.2,
      "text": "but something in me chooses"
    },
    {
      "start": 131.56,
      "end": 137.42,
      "text": "and that choosing sets me free"
    }
  ]
}
