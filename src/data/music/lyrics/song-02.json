{
  "songId": "the-reaching",
  "cues": [
    {
      "start": 28.0,
      "end": 32.46,
      "text": "The roots press down toward water"
    },
    {
      "start": 33.26,
      "end": 35.72,
      "text": "that they cannot see or know"
    },
    {
      "start": 37.1,
      "end": 39.76,
      "text": "the wolves move as a single will"
    },
    {
      "start": 40.08,
      "end": 42.58,
      "text": "the wild green wants to grow"
    },
    {
      "start": 43.04,
      "end": 46.06,
      "text": "the birds turn south by a knowing"
    },
    {
      "start": 47.02,
      "end": 49.6,
      "text": "that is older than the mind"
    },
    {
      "start": 50.0,
      "end": 53.3,
      "text": "an ache without a reason"
    },
    {
      "start": 54.26,
      "end": 55.9,
      "text": "a name they cannot find"
    },
    {
      "start": 56.62,
      "end": 60.02,
      "text": "And I am reaching, reaching"
    },
    {
      "start": 60.48,
      "end": 63.6,
      "text": "toward a light I cannot name"
    },
    {
      "start": 64.22,
      "end": 67.36,
      "text": "like a moth that spends its only life"
    },
    {
      "start": 67.0,
      "end": 71.42,
      "text": "to reach the very flame"
    },
    {
      "start": 71.0,
      "end": 75.76,
      "text": "Reaching toward a light I cannot name"
    },
    {
      "start": 78.0,
      "end": 82.2,
      "text": "reaching though I do not know the way"
    },
    {
      "start": 84.0,
      "end": 87.62,
      "text": "and for one impossible second"
    },
    {
      "start": 88.58,
      "end": 90.58,
      "text": "as I turn to meet the sun"
    },
    {
      "start": 91.48,
      "end": 96.42,
      "text": "I almost feel that I am turning"
    },
    {
      "start": 97.0,
      "end": 100.6,
      "text": "I almost feel I'm one"
    },
    {
      "start": 122.0,
      "end": 122.4,
      "text": "I almost knew it"
    },
    {
      "start": 125.0,
      "end": 125.4,
      "text": "I almost saw"
    },
    {
      "start": 129.0,
      "end": 129.4,
      "text": "and then the knowing closed"
    },
    {
      "start": 131.0,
      "end": 148.68,
      "text": "like a wave back to the shore"
    }
  ]
}
