{
  "songId": "a-million-years-ahead",
  "cues": [
    {
      "start": 20.5,
      "end": 23.22,
      "text": "I have walked the whole long stair now",
      "animationHint": "motif-return"
    },
    {
      "start": 23.84,
      "end": 26.42,
      "text": "the cold light and the flame, now one"
    },
    {
      "start": 27.44,
      "end": 30.44,
      "text": "and I turn and look back down"
    },
    {
      "start": 31.26,
      "end": 33.96,
      "text": "at the roads that I have run"
    },
    {
      "start": 34.02,
      "end": 38.48,
      "text": "and there — so small, so frightened —"
    },
    {
      "start": 38.54,
      "end": 41.24,
      "text": "behind a veil of years"
    },
    {
      "start": 42.08,
      "end": 45.1,
      "text": "is the one I used to be"
    },
    {
      "start": 45.74,
      "end": 56.74,
      "text": "in a world of doubt and tears"
    },
    {
      "start": 56.74,
      "end": 59.26,
      "text": "I remember standing in the dark",
      "animationHint": "higher-self-reveal"
    },
    {
      "start": 60.58,
      "end": 62.86,
      "text": "behind the veil you wore"
    },
    {
      "start": 63.24,
      "end": 65.78,
      "text": "I heard you asking for a sign"
    },
    {
      "start": 65.86,
      "end": 68.58,
      "text": "you'd heard a thousand times before"
    },
    {
      "start": 69.04,
      "end": 72.1,
      "text": "and I was there — I sent the pull"
    },
    {
      "start": 72.7,
      "end": 75.98,
      "text": "I lit the spark you couldn't see"
    },
    {
      "start": 76.38,
      "end": 79.54,
      "text": "because the one who needed guiding"
    },
    {
      "start": 80.46,
      "end": 83.46,
      "text": "was the self I used to be"
    },
    {
      "start": 83.46,
      "end": 87.02,
      "text": "I am your higher self",
      "animationHint": "chorus-bloom"
    },
    {
      "start": 87.34,
      "end": 90.4,
      "text": "I am the you a million years ahead"
    },
    {
      "start": 90.56,
      "end": 94.22,
      "text": "I watched you choose the light"
    },
    {
      "start": 94.22,
      "end": 97.72,
      "text": "from where the seventh meets the thread"
    },
    {
      "start": 98.22,
      "end": 100.78,
      "text": "the voice you couldn't place was mine"
    },
    {
      "start": 101.78,
      "end": 104.34,
      "text": "the hand you couldn't see"
    },
    {
      "start": 105.4,
      "end": 108.56,
      "text": "was reaching back across the veil"
    },
    {
      "start": 108.72,
      "end": 128.84,
      "text": "to help you home to me"
    },
    {
      "start": 128.84,
      "end": 131.68,
      "text": "The light you reached for in the dark —"
    },
    {
      "start": 131.68,
      "end": 133.78,
      "text": "it was always, always me"
    },
    {
      "start": 135.76,
      "end": 138.52,
      "text": "the name you could not find back then"
    },
    {
      "start": 138.72,
      "end": 141.2,
      "text": "was the name of who you'd be"
    },
    {
      "start": 141.26,
      "end": 145.22,
      "text": "so reach, my love, keep reaching"
    },
    {
      "start": 145.94,
      "end": 148.5,
      "text": "I'm standing where it ends:"
    },
    {
      "start": 149.3,
      "end": 151.88,
      "text": "you become the very light"
    },
    {
      "start": 152.88,
      "end": 157.4,
      "text": "you were reaching for back then"
    }
  ]
}
